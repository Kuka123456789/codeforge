---
/**
 * Animated mock of the CodeForge UI for the landing page hero.
 *
 * Pure HTML + CSS animation — no JS required.
 * Simulates: sidebar with projects/threads, a user prompt,
 * an AI response streaming code, and a diff panel sliding in.
 *
 * The entire animation loops every 16s.
 */
---

<div class="demo-wrap">
  <div class="demo-window">
    <!-- ── Title bar ── -->
    <div class="demo-titlebar">
      <div class="demo-dots">
        <span class="demo-dot demo-dot--red"></span>
        <span class="demo-dot demo-dot--yellow"></span>
        <span class="demo-dot demo-dot--green"></span>
      </div>
      <span class="demo-titlebar-text">CodeForge</span>
      <div class="demo-titlebar-spacer"></div>
    </div>

    <div class="demo-body">
      <!-- ── Sidebar ── -->
      <aside class="demo-sidebar">
        <div class="demo-sidebar-section">
          <span class="demo-sidebar-label">Projects</span>
          <div class="demo-sidebar-item demo-sidebar-item--active">
            <span class="demo-folder-icon">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>
            </span>
            codeforge
          </div>
        </div>

        <div class="demo-sidebar-section">
          <span class="demo-sidebar-label">Threads</span>
          <div class="demo-sidebar-item demo-sidebar-item--thread demo-sidebar-item--active">
            <span class="demo-status demo-status--running"></span>
            Add auth middleware
          </div>
          <div class="demo-sidebar-item demo-sidebar-item--thread">
            <span class="demo-status demo-status--done"></span>
            Fix API rate limiter
          </div>
          <div class="demo-sidebar-item demo-sidebar-item--thread">
            <span class="demo-status demo-status--done"></span>
            Refactor DB queries
          </div>
          <div class="demo-sidebar-item demo-sidebar-item--thread demo-sidebar-item--dim">
            <span class="demo-status demo-status--done"></span>
            Setup CI pipeline
          </div>
        </div>
      </aside>

      <!-- ── Main chat area ── -->
      <div class="demo-main">
        <!-- User message -->
        <div class="demo-msg demo-msg--user anim-msg-user">
          <div class="demo-msg-label">You</div>
          <div class="demo-msg-body">
            Add JWT authentication middleware to the Express server. It should validate tokens on all /api routes and attach the decoded user to req.user.
          </div>
        </div>

        <!-- AI response -->
        <div class="demo-msg demo-msg--ai anim-msg-ai">
          <div class="demo-msg-label">
            <span class="demo-provider-dot"></span>
            Claude
            <span class="demo-model-tag">Sonnet</span>
          </div>

          <div class="demo-msg-body demo-msg-body--thinking anim-thinking">
            <span class="demo-thinking-icon">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            </span>
            Analyzing project structure and existing middleware...
          </div>

          <div class="demo-msg-body anim-prose">
            I'll create the auth middleware and wire it into your Express app. Here's the implementation:
          </div>

          <!-- Code block -->
          <div class="demo-code-block anim-code">
            <div class="demo-code-header">
              <span class="demo-code-file">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>
                src/middleware/auth.ts
              </span>
              <span class="demo-code-badge">+42 lines</span>
            </div>
            <pre class="demo-code"><code><span class="hl-kw">import</span> <span class="hl-br">&#123;</span> <span class="hl-var">Request</span>, <span class="hl-var">Response</span>, <span class="hl-var">NextFunction</span> <span class="hl-br">&#125;</span> <span class="hl-kw">from</span> <span class="hl-str">"express"</span>;
<span class="hl-kw">import</span> jwt <span class="hl-kw">from</span> <span class="hl-str">"jsonwebtoken"</span>;

<span class="hl-kw">interface</span> <span class="hl-type">AuthPayload</span> <span class="hl-br">&#123;</span>
  <span class="hl-var">userId</span>: <span class="hl-type">string</span>;
  <span class="hl-var">email</span>: <span class="hl-type">string</span>;
  <span class="hl-var">role</span>: <span class="hl-str">"admin"</span> | <span class="hl-str">"user"</span>;
<span class="hl-br">&#125;</span>

<span class="hl-kw">export const</span> <span class="hl-fn">authenticate</span> = (
  <span class="hl-var">req</span>: <span class="hl-type">Request</span>,
  <span class="hl-var">res</span>: <span class="hl-type">Response</span>,
  <span class="hl-var">next</span>: <span class="hl-type">NextFunction</span>
) <span class="hl-kw">=&gt; &#123;</span>
  <span class="hl-kw">const</span> token = req.headers.authorization
    ?.replace(<span class="hl-str">"Bearer "</span>, <span class="hl-str">""</span>);

  <span class="hl-kw">if</span> (!token) <span class="hl-kw">return</span> res
    .status(<span class="hl-num">401</span>).json(<span class="hl-br">&#123;</span> error: <span class="hl-str">"Missing token"</span> <span class="hl-br">&#125;</span>);

  <span class="hl-kw">try</span> <span class="hl-br">&#123;</span>
    <span class="hl-kw">const</span> decoded = jwt.verify(
      token, process.env.JWT_SECRET!
    ) <span class="hl-kw">as</span> <span class="hl-type">AuthPayload</span>;
    req.user = decoded;
    next();
  <span class="hl-br">&#125;</span> <span class="hl-kw">catch</span> <span class="hl-br">&#123;</span>
    res.status(<span class="hl-num">403</span>).json(<span class="hl-br">&#123;</span> error: <span class="hl-str">"Invalid token"</span> <span class="hl-br">&#125;</span>);
  <span class="hl-br">&#125;</span>
<span class="hl-br">&#125;</span>;</code></pre>
          </div>

          <!-- Tool call -->
          <div class="demo-tool-call anim-tool">
            <div class="demo-tool-header">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
              <span>Created <strong>src/middleware/auth.ts</strong></span>
            </div>
          </div>
        </div>

        <!-- Composer bar -->
        <div class="demo-composer anim-composer">
          <div class="demo-composer-inner">
            <span class="demo-composer-placeholder">Ask anything, @tag files/folders, or use /model</span>
            <div class="demo-composer-meta">
              <span class="demo-composer-model">
                <span class="demo-provider-dot demo-provider-dot--sm"></span>
                Claude Sonnet
              </span>
              <span class="demo-composer-badge">Full access</span>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Diff panel ── -->
      <div class="demo-diff anim-diff">
        <div class="demo-diff-header">
          <span class="demo-diff-title">Changes</span>
          <span class="demo-diff-count">1 file</span>
        </div>
        <div class="demo-diff-file">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>
          <span>auth.ts</span>
          <span class="demo-diff-additions">+42</span>
        </div>
        <div class="demo-diff-lines">
          <div class="demo-diff-line demo-diff-line--add"><span class="demo-diff-ln">1</span><span class="hl-kw">import</span> &#123; Request &#125; <span class="hl-kw">from</span> <span class="hl-str">"express"</span>;</div>
          <div class="demo-diff-line demo-diff-line--add"><span class="demo-diff-ln">2</span><span class="hl-kw">import</span> jwt <span class="hl-kw">from</span> <span class="hl-str">"jsonwebtoken"</span>;</div>
          <div class="demo-diff-line demo-diff-line--empty"><span class="demo-diff-ln">3</span></div>
          <div class="demo-diff-line demo-diff-line--add"><span class="demo-diff-ln">4</span><span class="hl-kw">interface</span> <span class="hl-type">AuthPayload</span> &#123;</div>
          <div class="demo-diff-line demo-diff-line--add"><span class="demo-diff-ln">5</span>  userId: <span class="hl-type">string</span>;</div>
          <div class="demo-diff-line demo-diff-line--add"><span class="demo-diff-ln">6</span>  email: <span class="hl-type">string</span>;</div>
          <div class="demo-diff-line demo-diff-line--add"><span class="demo-diff-ln">7</span>  role: <span class="hl-str">"admin"</span> | <span class="hl-str">"user"</span>;</div>
          <div class="demo-diff-line demo-diff-line--add"><span class="demo-diff-ln">8</span>&#125;</div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* ══════════════════════════════════════════
     CONTAINER
     ══════════════════════════════════════════ */

  .demo-wrap {
    margin: 0 auto;
    width: min(95vw, 1400px);
    opacity: 0;
    transform: scale(0.98);
    animation: screenshot-in 1s ease-out 0.15s forwards;
  }

  .demo-window {
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: #0c0c0f;
    overflow: hidden;
    mask-image: linear-gradient(to bottom, black 80%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 80%, transparent 100%);
  }

  .demo-wrap::after {
    content: "";
    display: block;
    width: 100%;
    height: 40px;
    background: inherit;
    margin-top: -1px;
    opacity: 0.04;
    transform: scaleY(-1);
    mask-image: linear-gradient(to bottom, black 0%, transparent 60%);
    -webkit-mask-image: linear-gradient(to bottom, black 0%, transparent 60%);
    pointer-events: none;
  }

  @keyframes screenshot-in {
    from { opacity: 0; transform: scale(0.98); }
    to { opacity: 1; transform: scale(1); }
  }

  /* ══════════════════════════════════════════
     TITLE BAR
     ══════════════════════════════════════════ */

  .demo-titlebar {
    display: flex;
    align-items: center;
    padding: 12px 16px;
    background: #111114;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    gap: 12px;
  }

  .demo-dots {
    display: flex;
    gap: 6px;
  }

  .demo-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .demo-dot--red { background: #ff5f57; }
  .demo-dot--yellow { background: #febc2e; }
  .demo-dot--green { background: #28c840; }

  .demo-titlebar-text {
    font-size: 0.75rem;
    color: var(--fg-dim);
    flex: 1;
    text-align: center;
  }

  .demo-titlebar-spacer {
    width: 44px;
  }

  /* ══════════════════════════════════════════
     BODY LAYOUT
     ══════════════════════════════════════════ */

  .demo-body {
    display: flex;
    min-height: 440px;
    max-height: 440px;
    font-size: 0.78rem;
    line-height: 1.5;
  }

  /* ══════════════════════════════════════════
     SIDEBAR
     ══════════════════════════════════════════ */

  .demo-sidebar {
    width: 200px;
    min-width: 200px;
    background: #0e0e11;
    border-right: 1px solid rgba(255, 255, 255, 0.06);
    padding: 12px 0;
    overflow: hidden;
  }

  .demo-sidebar-section {
    margin-bottom: 16px;
  }

  .demo-sidebar-label {
    display: block;
    padding: 0 14px;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg-dim);
    margin-bottom: 6px;
  }

  .demo-sidebar-item {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 5px 14px;
    font-size: 0.74rem;
    color: var(--fg-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    cursor: default;
  }

  .demo-sidebar-item--active {
    color: var(--fg);
    background: rgba(255, 255, 255, 0.05);
  }

  .demo-sidebar-item--dim {
    opacity: 0.5;
  }

  .demo-folder-icon {
    display: flex;
    color: var(--fg-dim);
  }

  .demo-status {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .demo-status--running {
    background: #22c55e;
    box-shadow: 0 0 6px rgba(34, 197, 94, 0.5);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  .demo-status--done {
    background: var(--fg-dim);
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* ══════════════════════════════════════════
     MAIN CHAT AREA
     ══════════════════════════════════════════ */

  .demo-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 20px 24px 0;
    overflow: hidden;
    position: relative;
    min-width: 0;
  }

  /* ── Messages ── */

  .demo-msg {
    margin-bottom: 18px;
  }

  .demo-msg-label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.7rem;
    font-weight: 600;
    margin-bottom: 6px;
    color: var(--fg-muted);
  }

  .demo-msg--user .demo-msg-label {
    color: var(--fg);
  }

  .demo-msg-body {
    color: var(--fg-muted);
    line-height: 1.65;
    font-size: 0.78rem;
  }

  .demo-msg--user .demo-msg-body {
    color: var(--fg);
  }

  .demo-msg-body--thinking {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--fg-dim);
    font-size: 0.72rem;
    font-style: italic;
    margin-bottom: 8px;
  }

  .demo-thinking-icon {
    display: flex;
    color: var(--fg-dim);
    animation: spin 3s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .demo-provider-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: linear-gradient(135deg, #d97706, #f59e0b);
  }

  .demo-provider-dot--sm {
    width: 6px;
    height: 6px;
  }

  .demo-model-tag {
    font-size: 0.6rem;
    font-weight: 500;
    color: var(--fg-dim);
    background: rgba(255, 255, 255, 0.06);
    padding: 1px 6px;
    border-radius: 4px;
  }

  /* ── Code block ── */

  .demo-code-block {
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: #111114;
    margin: 10px 0;
    overflow: hidden;
  }

  .demo-code-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 12px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    font-size: 0.68rem;
    color: var(--fg-dim);
  }

  .demo-code-file {
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .demo-code-badge {
    font-size: 0.6rem;
    color: #22c55e;
    background: rgba(34, 197, 94, 0.1);
    padding: 1px 6px;
    border-radius: 4px;
  }

  .demo-code {
    padding: 12px 14px;
    font-family: "SF Mono", "Fira Code", "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.66rem;
    line-height: 1.7;
    overflow: hidden;
    color: #d4d4d8;
    white-space: pre;
    max-height: 200px;
  }

  /* Syntax highlighting */
  .hl-kw { color: #c084fc; }
  .hl-str { color: #86efac; }
  .hl-fn { color: #60a5fa; }
  .hl-type { color: #67e8f9; }
  .hl-var { color: #fbbf24; }
  .hl-num { color: #fb923c; }
  .hl-br { color: #a1a1aa; }

  /* ── Tool call ── */

  .demo-tool-call {
    margin: 8px 0;
  }

  .demo-tool-header {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.7rem;
    color: #22c55e;
    padding: 6px 10px;
    background: rgba(34, 197, 94, 0.06);
    border: 1px solid rgba(34, 197, 94, 0.12);
    border-radius: 8px;
  }

  .demo-tool-header strong {
    color: var(--fg-muted);
  }

  /* ── Composer ── */

  .demo-composer {
    margin-top: auto;
    padding: 12px 0 16px;
  }

  .demo-composer-inner {
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 12px 14px;
    background: rgba(255, 255, 255, 0.02);
  }

  .demo-composer-placeholder {
    font-size: 0.74rem;
    color: var(--fg-dim);
    opacity: 0.6;
  }

  .demo-composer-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 8px;
  }

  .demo-composer-model {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.62rem;
    color: var(--fg-dim);
  }

  .demo-composer-badge {
    font-size: 0.58rem;
    color: #22c55e;
    background: rgba(34, 197, 94, 0.08);
    padding: 1px 6px;
    border-radius: 4px;
  }

  /* ══════════════════════════════════════════
     DIFF PANEL
     ══════════════════════════════════════════ */

  .demo-diff {
    width: 220px;
    min-width: 220px;
    background: #0e0e11;
    border-left: 1px solid rgba(255, 255, 255, 0.06);
    padding: 12px 0;
    overflow: hidden;
  }

  .demo-diff-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 12px 10px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    margin-bottom: 8px;
  }

  .demo-diff-title {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--fg);
  }

  .demo-diff-count {
    font-size: 0.6rem;
    color: var(--fg-dim);
  }

  .demo-diff-file {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    font-size: 0.68rem;
    color: var(--fg-muted);
    background: rgba(255, 255, 255, 0.03);
    margin-bottom: 8px;
  }

  .demo-diff-additions {
    margin-left: auto;
    font-size: 0.6rem;
    color: #22c55e;
  }

  .demo-diff-lines {
    padding: 0 4px;
  }

  .demo-diff-line {
    display: flex;
    align-items: baseline;
    gap: 0;
    font-family: "SF Mono", "Fira Code", ui-monospace, monospace;
    font-size: 0.58rem;
    line-height: 1.7;
    padding: 0 8px;
    white-space: nowrap;
    overflow: hidden;
  }

  .demo-diff-line--add {
    background: rgba(34, 197, 94, 0.06);
    color: #d4d4d8;
  }

  .demo-diff-line--empty {
    color: transparent;
  }

  .demo-diff-ln {
    width: 22px;
    min-width: 22px;
    text-align: right;
    color: rgba(255, 255, 255, 0.15);
    margin-right: 8px;
    user-select: none;
  }

  /* ══════════════════════════════════════════
     STAGGERED ENTRANCE ANIMATIONS
     ══════════════════════════════════════════ */

  .anim-msg-user {
    opacity: 0;
    animation: fade-up 0.5s ease-out 0.8s forwards;
  }

  .anim-msg-ai {
    opacity: 0;
    animation: fade-up 0.5s ease-out 1.6s forwards;
  }

  .anim-thinking {
    opacity: 0;
    animation:
      fade-up 0.4s ease-out 2.0s forwards,
      fade-out 0.5s ease-in 3.2s forwards;
  }

  .anim-prose {
    opacity: 0;
    animation: fade-up 0.4s ease-out 3.0s forwards;
  }

  .anim-code {
    opacity: 0;
    animation: fade-up 0.6s ease-out 3.6s forwards;
  }

  .anim-tool {
    opacity: 0;
    animation: fade-up 0.4s ease-out 4.6s forwards;
  }

  .anim-diff {
    opacity: 0;
    animation: slide-in-right 0.6s ease-out 5.0s forwards;
  }

  .anim-composer {
    opacity: 0;
    animation: fade-up 0.3s ease-out 0.6s forwards;
  }

  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fade-out {
    from { opacity: 1; }
    to { opacity: 0; height: 0; margin: 0; padding: 0; overflow: hidden; }
  }

  @keyframes slide-in-right {
    from {
      opacity: 0;
      transform: translateX(20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* ══════════════════════════════════════════
     RESPONSIVE
     ══════════════════════════════════════════ */

  @media (max-width: 900px) {
    .demo-diff {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .demo-sidebar {
      width: 140px;
      min-width: 140px;
    }

    .demo-body {
      min-height: 340px;
      max-height: 340px;
    }

    .demo-code {
      font-size: 0.58rem;
    }

    .demo-wrap {
      width: 95vw;
    }
  }

  @media (max-width: 480px) {
    .demo-sidebar {
      display: none;
    }
  }
</style>
