{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist-electron/**"],
    },
    "dev": {
      "dependsOn": ["codeforge-chat#build"],
      "persistent": true,
    },
    "start": {
      "dependsOn": ["build", "@codeforge/web#build", "codeforge-chat#build"],
      "cache": false,
      "persistent": true,
    },
    "smoke-test": {
      "dependsOn": ["build", "@codeforge/web#build", "codeforge-chat#build"],
      "cache": false,
      "outputs": [],
    },
  },
}
